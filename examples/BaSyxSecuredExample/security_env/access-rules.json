{
  "AllAccessPermissionRules": {
    "DEFATTRIBUTES": [
      { "name": "anonymous_attr", "attributes": [ { "GLOBAL": "ANONYMOUS" } ] },
      { "name": "username_attr", "attributes": [ { "CLAIM": "role" } ] }
    ],
    "DEFOBJECTS": [
      { "name": "public_description", "objects": [ { "ROUTE": "/description" }] },
      { "name": "public_aas", "objects": [ 
        { "IDENTIFIABLE": "$aas(\"https://htw-berlin.de/ids/aas/demoaasv3\")" },
        { "IDENTIFIABLE": "$sm(\"https://htw-berlin.de/ids/sm/demosubmodelv3\")" }, 
        { "DESCRIPTOR": "$aasdesc(\"https://htw-berlin.de/ids/aas/demoaasv3\")" } , 
        { "DESCRIPTOR": "$smdesc(\"https://htw-berlin.de/ids/sm/demosubmodelv3\")" }
      ] },
      { "name": "all_api", "objects": [
        { "ROUTE": "/health" },
        { "ROUTE": "/shell-descriptors" },
        { "ROUTE": "/shell-descriptors/*" },
        { "ROUTE": "/submodel-descriptors" },
        { "ROUTE": "/submodel-descriptors/*" },
        { "ROUTE": "/lookup/shells" },
        { "ROUTE": "/lookup/shells/*" },
        { "ROUTE": "/lookup/shellsByAssetLink" },
        { "ROUTE": "/shells" },
        { "ROUTE": "/shells/*" },
        { "ROUTE": "/submodels" },
        { "ROUTE": "/submodels/*" },
        { "ROUTE": "/concept-descriptions" },
        { "ROUTE": "/concept-descriptions/*" }
      ] }
    ],
    "DEFACLS": [
      { "name": "anonymous_read", "acl": { "USEATTRIBUTES": "anonymous_attr", "RIGHTS": ["READ"], "ACCESS": "ALLOW" } },
      { "name": "user", "acl": { "USEATTRIBUTES": "username_attr", "RIGHTS": ["READ"], "ACCESS": "ALLOW" } },
      { "name": "admin", "acl": { "USEATTRIBUTES": "username_attr", "RIGHTS": ["ALL"], "ACCESS": "ALLOW" } }
    ],
    "DEFFORMULAS": [
      { "name": "is_admin", "formula": { "$eq": [ { "$attribute": { "CLAIM": "role" } }, { "$strVal": "admin" } ] } },
      { "name": "is_user", "formula": { "$eq": [ { "$attribute": { "CLAIM": "role" } }, { "$strVal": "viewer" } ] } }
    ],
    "rules": [
      { "USEACL": "anonymous_read", "USEOBJECTS": ["public_description", "public_aas"], "FORMULA": {"$boolean": true} },
      { "USEACL": "user", "USEOBJECTS": ["all_api"], "USEFORMULA": "is_user" },
      { "USEACL": "admin", "USEOBJECTS": ["all_api"], "USEFORMULA": "is_admin" }
    ]
  }
}
