{
  "AllAccessPermissionRules": {
    "rules": [
      {
        "ACL": {
          "ACCESS": "ALLOW",
          "ATTRIBUTES": [
            {
              "GLOBAL": "ANONYMOUS"
            }
          ],
          "RIGHTS": ["READ","UPDATE"]
        },
        "OBJECTS": [
          {
            "ROUTE": "/*"
          }
        ],
        "FORMULA": {
          "$and": [
            {"$boolean": true},
            {"$eq": [{"$numVal": 1}, {"$numVal": 1}]}
          ]
        }
      }
    ]
  }
}
